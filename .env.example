CV_IMAGE_PROVIDER=openai
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-1

AZURE_OPENAI_API_KEY=your_azure_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_IMAGE_DEPLOYMENT=your_image_deployment_name
AZURE_OPENAI_API_VERSION=2025-04-01-preview

REPLICATE_API_TOKEN=your_replicate_token_here
REPLICATE_MODEL_PATH=black-forest-labs/flux-kontext-pro
# Optional field overrides for replicate if your chosen model expects different input names
# REPLICATE_PROMPT_FIELD=prompt
# REPLICATE_IMAGE_FIELD=input_image
# REPLICATE_EXTRA_INPUT_JSON={"aspect_ratio":"1:1","output_format":"jpg"}

# Optional prompt override for portrait retouching
# CV_PORTRAIT_PROMPT=Create a realistic business headshot with neutral background, subtle ageing, natural grey in the beard, and authentic skin texture.